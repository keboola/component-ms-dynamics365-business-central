{
  "type": "object",
  "title": "Dynamics 365 Business Central Configuration",
  "required": [
    "connection"
  ],
  "properties": {
    "connection": {
      "type": "object",
      "title": "Connection",
      "required": [
        "tenant_id"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "title": "Tenant ID",
          "description": "Can be found in https://businesscentral.dynamics.com/__TENANT_ID__/Production",
          "propertyOrder": 1
        },
        "company_id": {
          "type": "string",
          "enum": [],
          "default": "",
          "format": "select",
          "title": "Company ID",
          "description": "GUID of the company to extract data from",
          "options": {
            "async": {
              "label": "Load companies",
              "action": "list_companies"
            }
          },
          "propertyOrder": 2
        },
        "environment": {
          "type": "string",
          "enum": [],
          "default": "",
          "format": "select",
          "title": "Environment",
          "description": "Business Central environment name (e.g. Production, Sandbox)",
          "options": {
            "async": {
              "label": "Load environments",
              "action": "list_environments"
            }
          },
          "propertyOrder": 3
        },
        "test_connection": {
          "type": "button",
          "format": "test-connection",
          "propertyOrder": 4
        }
      },
      "propertyOrder": 100
    }
  }
}